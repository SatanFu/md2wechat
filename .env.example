# 必填：微信公众号凭证
WXGZH_APPID=your_appid_here
WXGZH_APPSECRET=your_appsecret_here

# 默认行为
WXGZH_DEFAULT_AUTHOR=tenisinfinite
WXGZH_DEFAULT_THEME=default
WXGZH_DEFAULT_COVER_STRATEGY=sharp

# AI 封面 — Google Imagen（可选）
# 通过 Gemini API 调用 Imagen 4 生图
# 获取 API Key: https://aistudio.google.com/apikey
IMAGEN_API_KEY=
# 可选：指定模型，默认 imagen-4.0-fast-generate-001
# 可选值: imagen-4.0-fast-generate-001 / imagen-4.0-generate-001 / imagen-4.0-ultra-generate-001
IMAGEN_MODEL=

# 数据库（不填则用 SQLite）
DATABASE_URL=

# Webhook（可选）
WEBHOOK_URL=

# 服务配置
API_KEY=
PORT=3090
MAX_FILE_SIZE_MB=10
LOG_LEVEL=info
